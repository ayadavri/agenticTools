RI_CORE_BASE_URL=https://test-ri-core.residentinterface.com
# Direct key (local dev). Do not expose via MCP tool schema.
RI_CORE_API_KEY=
RI_CORE_HTTP_TIMEOUT_S=30
AWS_REGION=us-east-1
# SSM alternative (Lambda needs ssm:GetParameter on this name)
COLLECTION_CORE_DOCUMENTS_API_SSM_PARAMETER=/agents/COLLECTION_CORE_DOCUMENTS_API_KEY
# Preferred with AgentCore Identity: secret ARN from `agentcore add credential --type api-key`
RI_CORE_API_KEY_SECRET_ARN=
